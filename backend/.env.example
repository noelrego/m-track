NODE_ENV=development
TZ=UTC
LOG_LEVEL=debug
PORT=3000
API_GLOBAL_PREFIX=api
MONGO_URI=mongodb://mongo:27017/m_track
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRES_IN=1h
JWT_TRANSPORT=bearer
# JWT_COOKIE_* values are only used when JWT_TRANSPORT=cookie.
JWT_COOKIE_NAME=m_track_access_token
JWT_COOKIE_MAX_AGE_MS=3600000
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax
# Production bearer frontend/API example:
# CORS_ORIGIN=https://your-vercel-app.vercel.app
ROOT_ADMIN_USERNAME=rootadmin
ROOT_ADMIN_EMAIL=rootadmin@example.com
ROOT_ADMIN_PASSWORD=change-this-root-password
ROOT_ADMIN_FIRST_NAME=Root
ROOT_ADMIN_LAST_NAME=Admin
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
